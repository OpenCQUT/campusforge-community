# App
NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1

# Backend
DATABASE_URL=postgresql://campusforge:campusforge@localhost:5432/campusforge?schema=public
