# App
NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1

# Test account (dev only — never commit real credentials)
NEXT_PUBLIC_ADMIN_EMAIL=test@admin.edu
CAMPUSFORGE_SESSION_SECRET=replace-with-a-long-random-secret

# Debug mode (set to "true" for local dev)
NEXT_PUBLIC_DEBUG=true

# Runtime storage paths
CAMPUSFORGE_DATA_DIR=.campusforge-data
CAMPUSFORGE_LOG_DIR=.campusforge-logs

# Backend
CORS_ORIGIN=http://localhost:3000
REPOSITORY_MODE=mock

# ─── Below are not yet used by the API, but kept for future reference ───
# DATABASE_URL=postgresql://campusforge:campusforge@localhost:5432/campusforge?schema=public
# REDIS_URL=redis://localhost:6379
# JWT_SECRET=replace-with-a-long-random-secret
# INVITE_REVIEW_SLA_HOURS=48
# ALLOWED_EMAIL_DOMAINS=school.edu,university.edu
