{
  "name": "campusforge",
  "version": "0.1.0",
  "private": true,
  "description": "Invitation-first school internal open-source community platform.",
  "license": "MIT",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @campusforge/db exec prisma generate --schema prisma/schema.prisma",
    "db:migrate": "pnpm --filter @campusforge/db exec prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "pnpm --filter @campusforge/db db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
